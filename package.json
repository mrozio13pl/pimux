{
    "name": "pimux",
    "version": "0.3.0",
    "private": true,
    "description": "Pimux multiplexer",
    "author": {
        "name": "mrozio13pl",
        "email": "mrozio13pl@gmail.com"
    },
    "bin": {
        "pimux": "out/cli/index.mjs"
    },
    "main": "out/main/index.js",
    "scripts": {
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "dev": "vite",
        "cli": "vite-node cli/index.ts",
        "build": "pnpm icons && vite build && vite build --mode cli",
        "test": "vitest run",
        "preview": "vite preview --outDir out/renderer",
        "prepare": "simple-git-hooks",
        "postinstall": "node scripts/electron-install.mjs",
        "typecheck": "tsc --noEmit",
        "dist": "pnpm build && electron-builder",
        "dist:dir": "pnpm build && electron-builder --dir",
        "dist:linux": "pnpm build && electron-builder --linux",
        "dist:win": "pnpm build && electron-builder --win",
        "dist:mac": "pnpm build && electron-builder --mac",
        "icons": "node scripts/generate-icons.mjs"
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fontsource-variable/raleway": "^5.2.8",
        "@phosphor-icons/react": "^2.1.10",
        "@pierre/diffs": "^1.2.3",
        "@xterm/addon-canvas": "^0.7.0",
        "@xterm/addon-clipboard": "^0.2.0",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/addon-search": "^0.16.0",
        "@xterm/addon-serialize": "^0.14.0",
        "@xterm/addon-unicode11": "^0.9.0",
        "@xterm/addon-web-links": "^0.12.0",
        "@xterm/xterm": "^6.0.0",
        "class-variance-authority": "^0.7.1",
        "cleye": "^2.6.0",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "culori": "^4.0.2",
        "date-fns": "^4.3.0",
        "get-port": "^7.2.0",
        "node-pty": "^1.1.0",
        "open-editor": "^6.0.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-resizable-panels": "^4.11.2",
        "tailwind-merge": "^3.6.0",
        "tinykeys": "^4.0.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@earendil-works/pi-coding-agent": "^0.78.0",
        "@tailwindcss/vite": "^4.3.0",
        "@types/culori": "^4.0.1",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "electron": "42.2.0",
        "electron-builder": "^26.8.1",
        "nano-staged": "^1.0.2",
        "oxfmt": "^0.52.0",
        "oxlint": "^1.67.0",
        "png2icons": "^2.0.1",
        "sharp": "^0.34.5",
        "simple-git-hooks": "^2.13.1",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vite-node": "^6.0.0",
        "vite-plugin-electron": "^0.29.1",
        "vitest": "^4.1.7"
    },
    "simple-git-hooks": {
        "commit-msg": "pnpm exec commitlint --edit $1",
        "pre-commit": "pnpm exec nano-staged"
    },
    "nano-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs}": [
            "oxfmt",
            "oxlint --fix"
        ],
        "*.{json,jsonc,md,yml,yaml,css,html}": [
            "oxfmt"
        ]
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@11.3.0",
    "build": {
        "appId": "dev.pimux.app",
        "productName": "Pimux",
        "directories": {
            "output": "release"
        },
        "files": [
            "out/**",
            "assets/**",
            "package.json"
        ],
        "asarUnpack": [
            "node_modules/node-pty/**"
        ],
        "npmRebuild": true,
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.developer-tools",
            "icon": "assets/icons/icon.icns"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "assets/icons/icon.ico"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb",
                "pacman"
            ],
            "category": "Development",
            "icon": "assets/icons"
        }
    }
}
